<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>Complaint Wizard User</label>
    <description>Grants access to Complaint__c object and all its fields. Required for the complaint wizard to load picklist values and create complaint records in Experience Cloud or Lightning
pages.</description>

    <objectPermissions>
        <object>Complaint__c</object>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>

