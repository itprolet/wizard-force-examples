    <hasActivationRequired>false</hasActivationRequired>
    <label>Wizard Smoke Test</label>
    <applicationVisibilities>
        <application>Wizard_Smoke</application>
        <visible>true</visible>
    </applicationVisibilities>
    <tabSettings>
        <tab>Wizard_TEST_Smoke</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
          <tab>Style_Showcase</tab>
          <visibility>Visible</visibility>
      </tabSettings>
</PermissionSet>
